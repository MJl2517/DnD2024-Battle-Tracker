{
  "name": "dnd-2024-battle-tracker",
  "version": "0.2.0",
  "description": "Desktop initiative and HP tracker for DnD 2024 encounters.",
  "private": true,
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite build && node scripts/dev.mjs",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dist.ps1",
    "dist:publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dist.ps1 -Publish always",
    "postinstall": "electron-builder install-app-deps",
    "preview": "electron-vite preview",
    "rebuild": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude src/main/repositories/repository.integration.test.ts",
    "test:integration": "node scripts/vitest-electron.mjs",
    "test:e2e": "npm.cmd run build && playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm.cmd run format:check && npm.cmd run lint && npm.cmd run typecheck && npm.cmd run test:coverage && npm.cmd run test:integration && npm.cmd run test:e2e",
    "git:pull": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/git-pull.ps1",
    "git:push": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/git-push.ps1",
    "release:publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/github-release.ps1",
    "release:build-publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/github-release.ps1 -Build"
  },
  "dependencies": {
    "@dice-roller/rpg-dice-roller": "^5.5.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.38.4",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@swc/core": "^1.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "local.dnd2024.battletracker",
    "productName": "DnD 2024 Battle Tracker",
    "icon": "build/icon",
    "artifactName": "DnD-2024-Battle-Tracker-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "MJl2517",
        "repo": "DnD2024-Battle-Tracker"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DnD 2024 Battle Tracker",
      "uninstallDisplayName": "DnD 2024 Battle Tracker",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    }
  }
}
